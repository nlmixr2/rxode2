linters: linters_with_defaults(
    object_name_linter(
      styles = "camelCase",
      regexes = c(
        internal = "^\\.[a-z][a-zA-Z0-9]*$",
        s3 = "^[a-z][a-z0-9_]*\\.[a-zA-Z][a-zA-Z0-9]*$"
      )
    ),
    assignment_linter(),
    line_length_linter(120),
    no_tab_linter(),
    non_ascii_linter(),
    pipe_continuation_linter(),
    T_and_F_symbol_linter(),
    infix_spaces_linter = NULL, # Keep disabled for now due to high violation count (8541)
    commas_linter = NULL, # Keep disabled for now (2242)
    cyclocomp_linter(50)
  )
exclusions: list(
    "tests/testthat.R",
    "tests/testthat/etTrans-drop.rds",
    "tests/testthat/f1.d/extraC.h",
